# ===== API Key Handling =====
def load_api_key():
    if os.path.exists(API_KEY_FILE):
        with open(API_KEY_FILE, "r", encoding="utf-8") as f:
            return json.load(f).get("api_key")
    return None


def save_api_key(api_key):
    with open(API_KEY_FILE, "w", encoding="utf-8") as f:
        json.dump({"api_key": api_key}, f, indent=4)


def get_api_key():
    api_key = load_api_key()
    if api_key:
        print(f"{Fore.CYAN}Loaded saved API key from {API_KEY_FILE}{Style.RESET_ALL}")
        use_saved = input("Do you want to use this key? [Y/n]: ").strip().lower()
        if use_saved != "n":
            return api_key

    api_key = input("Enter your VirusTotal API key: ").strip()
    save_api_key(api_key)
    print(f"{Fore.CYAN}API key saved to {API_KEY_FILE}{Style.RESET_ALL}")
    return api_key


# ===== Whitelist Handling =====
